generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  OWNER
  ADMIN
  USER
}

enum Gender {
  MALE
  FEMALE
}

enum Relationship {
  SPOUSE
  SIBLING
  PARENT
  CHILD
  FRIEND
  COLLEAGUE
  NEIGHBOR
  ACQUAINTANCE
  RELATIVE
  EMPLOYER
  EMPLOYEE
  OTHER
}

enum MembershipInterest {
  E_AJO
  SAVINGS
  LOAN
}

enum Assumptions {
  HAS_SMART_PHONE
  HAS_INTEGRITY
  IS_TRUSTWORTHY
  HAS_INTERNET_ACCESS
  HAS_EMAIL
  HAS_WHATS_APP
}

enum MembershipStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED // For yearly renewal tracking
}

enum MembershipTier {
  MEMBER // Loan only
  SILVER_MEMBER // Ajo participant
  GOLD_MEMBER // Savings participant
}

// ============================================
// CORE USER MODELS
// ============================================
model User {
  id             String    @id @default(uuid())
  email          String    @unique
  username       String    @unique @default(uuid())
  name           String
  passwordHash   String? // Optional: null until user sets password
  photoUrl       String?
  role           UserRole  @default(USER)
  emailVerified  DateTime? // For email verification
  hasSetPassword Boolean   @default(false) // Track if user has activated account
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  accounts     Account[]
  sessions     Session[]
  userInfo     UserInfo?
  bankAccounts BankAccount[]
  nextOfKin    NextOfKin?
  membership   Membership?

  @@map("users")
}

model Account {
  id                String   @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model UserInfo {
  id          String    @id @default(uuid())
  address     String?
  dateOfBirth DateTime?
  gender      Gender?
  occupation  String?
  phoneNumber String?
  userId      String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_info")
}

model BankAccount {
  id            String   @id @default(uuid())
  accountNumber String
  accountName   String
  bankName      String
  userId        String
  isPrimary     Boolean  @default(false) // Mark primary account
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bank_accounts")
}

model NextOfKin {
  id            String       @id @default(uuid())
  name          String
  phoneNumber   String
  relationship  Relationship
  bankName      String
  accountNumber String
  accountName   String
  occupation    String
  address       String
  userId        String       @unique
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("next_of_kins")
}

model Membership {
  id                  String               @id @default(uuid())
  sourceOfIncome      String[]
  interests           MembershipInterest[]
  referralName        String?
  referralPhoneNumber String?
  membershipNumber    String?              @unique
  assumptions         Assumptions[]
  tier                MembershipTier       @default(MEMBER)
  status              MembershipStatus     @default(PENDING)
  approvedAt          DateTime?
  approvedBy          String?
  rejectionReason     String?
  membershipFee       Decimal              @default(0) // Currently 0, future: 5000
  renewalFee          Decimal              @default(0) // Currently 0, future: 2000
  expiryDate          DateTime? // For yearly renewal
  lastRenewalDate     DateTime?
  userId              String               @unique
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("memberships")
}
