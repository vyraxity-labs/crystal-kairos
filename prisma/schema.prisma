generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  OWNER
  ADMIN
  USER
}

enum Gender {
  MALE
  FEMALE
}

enum Relationship {
  SPOUSE
  SIBLING
  PARENT
  CHILD
  FRIEND
  COLLEAGUE
  NEIGHBOR
  ACQUAINTANCE
  RELATIVE
  EMPLOYER
  EMPLOYEE
  OTHER
}

enum MembershipInterest {
  E_AJO
  SAVINGS
  LOAN
}

enum Assumptions {
  HAS_SMART_PHONE
  HAS_INTEGRITY
  IS_TRUSTWORTHY
  HAS_INTERNET_ACCESS
  HAS_EMAIL
  HAS_WHATS_APP
}

enum MembershipStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED // For yearly renewal tracking
}

enum MembershipTier {
  MEMBER // Loan only
  SILVER_MEMBER // Ajo participant
  GOLD_MEMBER // Savings participant
}

enum NotificationChannel {
  EMAIL
  IN_APP
  PUSH
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  READ
}

enum NotificationEventType {
  // System-triggered
  MEMBER_REGISTERED
  MEMBERSHIP_APPROVED
  MEMBERSHIP_REJECTED
  MEMBERSHIP_EXPIRED
  PASSWORD_SET
  // Admin-triggered
  CUSTOM
}

// ============================================
// CORE USER MODELS
// ============================================
model User {
  id                     String         @id @default(uuid())
  email                  String         @unique
  username               String         @unique @default(uuid())
  name                   String
  passwordHash           String? // Optional: null until user sets password
  photoUrl               String?
  role                   UserRole       @default(USER)
  emailVerified          DateTime? // For email verification
  hasSetPassword         Boolean        @default(false) // Track if user has activated account
  lastLoginAt            DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  receivedNotifications  Notification[] @relation("ReceivedNotifications")
  triggeredNotifications Notification[] @relation("TriggeredNotifications")

  // Relations
  accounts     Account[]
  sessions     Session[]
  userInfo     UserInfo?
  bankAccounts BankAccount[]
  nextOfKin    NextOfKin?
  membership   Membership?

  @@map("users")
}

model Account {
  id                String   @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model UserInfo {
  id          String    @id @default(uuid())
  address     String?
  dateOfBirth DateTime?
  gender      Gender?
  occupation  String?
  phoneNumber String?
  userId      String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_info")
}

model BankAccount {
  id            String   @id @default(uuid())
  accountNumber String
  accountName   String
  bankName      String
  userId        String
  isPrimary     Boolean  @default(false) // Mark primary account
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bank_accounts")
}

model NextOfKin {
  id            String       @id @default(uuid())
  name          String
  phoneNumber   String
  relationship  Relationship
  bankName      String
  accountNumber String
  accountName   String
  occupation    String
  address       String
  userId        String       @unique
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("next_of_kins")
}

model Membership {
  id                  String               @id @default(uuid())
  sourceOfIncome      String[]
  interests           MembershipInterest[]
  referralName        String?
  referralPhoneNumber String?
  membershipNumber    String?              @unique
  assumptions         Assumptions[]
  tier                MembershipTier       @default(MEMBER)
  status              MembershipStatus     @default(PENDING)
  approvedAt          DateTime?
  approvedBy          String?
  rejectionReason     String?
  membershipFee       Decimal              @default(0) // Currently 0, future: 5000
  renewalFee          Decimal              @default(0) // Currently 0, future: 2000
  expiryDate          DateTime? // For yearly renewal
  lastRenewalDate     DateTime?
  userId              String               @unique
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("memberships")
}

model NotificationTemplate {
  id          String   @id @default(uuid())
  name        String   @unique // e.g. "welcome_email"
  subject     String
  htmlBody    String // HTML with {{variable}} placeholders
  variables   String[] // list of variable names e.g. ["memberName", "date"]
  description String?
  isSystem    Boolean  @default(false) // system templates can't be deleted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  notifications Notification[]

  @@map("notification_templates")
}

model Notification {
  id      String                @id @default(uuid())
  type    NotificationEventType
  channel NotificationChannel
  status  NotificationStatus    @default(PENDING)

  // Who sent it
  triggeredBy String? // userId of admin, null = system

  // Who receives it
  recipientId String // userId

  // Content
  subject    String?
  body       String // final rendered HTML or text
  templateId String?
  variables  Json? // snapshot of variables used

  // Metadata
  externalId  String? // e.g. Resend message ID
  errorMsg    String?
  readAt      DateTime?
  sentAt      DateTime?
  deliveredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipient User                  @relation("ReceivedNotifications", fields: [recipientId], references: [id])
  triggerer User?                 @relation("TriggeredNotifications", fields: [triggeredBy], references: [id])
  template  NotificationTemplate? @relation(fields: [templateId], references: [id])

  @@map("notifications")
}
